<?xml version="1.0" encoding="utf-8"?>
<!--
    Este archivo es el certificado oficial de Google que Android necesita
    para verificar que las fuentes vienen de una fuente de confianza.

    Colócalo en: res/values/font_certs.xml
    No toques el contenido, es el certificado oficial de Google.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>

    <!-- Certificado de desarrollo -->
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>

    <!-- Certificado de producción -->
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>